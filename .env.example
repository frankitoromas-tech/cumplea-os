# Core runtime
FLASK_DEBUG=0
PORT=5000
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=*

# Telegram integration (required for message notifications)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: persist data on a mounted volume (example: /app/data)
APP_DATA_DIR=.

# Security hardening
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=
MAX_CONTENT_LENGTH_BYTES=262144
LEGACY_PLAINTEXT_MESSAGE_LOG=0
