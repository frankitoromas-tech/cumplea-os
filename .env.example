# Core runtime
FLASK_DEBUG=0
PORT=5000
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=*

# Telegram integration (required for message notifications)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: persist data on a mounted volume (example: /app/data)
APP_DATA_DIR=.
FECHA_APERTURA_ISO=2026-08-30T00:00:00
PREVIEW_MODE_ENABLED=0

# Security hardening
# Rechaza POST cross-site cuando Origin/Referer no coincide (prod: 1)
ENFORCE_SAME_ORIGIN_WRITES=0
# Desactiva ?admin_token= en APIs JSON (usar header o cookie)
ADMIN_TOKEN_QUERY_ALLOWED=0
# Encryption at rest. Comma-separated keys enable rotation
# (first key encrypts, any key can decrypt).
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=

# Token required to reach /admin and admin-only APIs (/api/salud, /api/test_telegram).
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=

# Limites de entrada y compatibilidad
MAX_CONTENT_LENGTH_BYTES=262144
LEGACY_PLAINTEXT_MESSAGE_LOG=0
