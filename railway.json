{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": [
      "app.py",
      "api/**",
      "controllers/**",
      "services/**",
      "models/**",
      "templates/**",
      "static/**",
      "requirements.txt",
      "gunicorn.conf.py",
      "Dockerfile",
      "nixpacks.toml",
      "railway.json"
    ]
  },
  "deploy": {
    "startCommand": "gunicorn app:app -c gunicorn.conf.py --workers 1 --threads 4 --bind 0.0.0.0:${PORT:-8000}",
    "healthcheckPath": "/healthz",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
