diff --git a/static/styless.css b/static/styless.css
index cd44316..a48a344 100644
--- a/static/styless.css
+++ b/static/styless.css
@@ -653,3 +653,65 @@ body {
     .panel-comandos-luna { right: 10px; top: auto; bottom: 10px; width: calc(100vw - 20px); }
     .layout-masonry { column-count: 2; }
 }
+
+/* ====================================================================
+   12. AJUSTES PRO: LUNA, VELAS Y ACCESO DIRECTO
+   ==================================================================== */
+.btn-luna-directa {
+    margin-left: 8px;
+    background: linear-gradient(135deg, #8b5cf6, #ec4899) !important;
+}
+
+.luna-realista {
+    position: relative;
+    overflow: hidden;
+    animation: respirarLuz 5s ease-in-out infinite;
+}
+.luna-realista::before,
+.luna-realista::after {
+    content: '';
+    position: absolute;
+    border-radius: 50%;
+    background: rgba(71,85,105,0.25);
+}
+.luna-realista::before { width: 55px; height: 55px; top: 62px; left: 48px; }
+.luna-realista::after { width: 34px; height: 34px; top: 108px; left: 146px; }
+
+@keyframes respirarLuz {
+    0%, 100% { transform: translateY(0) scale(1); filter: drop-shadow(0 0 20px rgba(255,255,255,0.2)); }
+    50% { transform: translateY(-6px) scale(1.02); filter: drop-shadow(0 0 34px rgba(255,255,255,0.45)); }
+}
+
+.onda-luz {
+    position: absolute;
+    left: 50%;
+    top: 50%;
+    width: 10px;
+    height: 10px;
+    border-radius: 50%;
+    border: 2px solid rgba(255,255,255,0.8);
+    transform: translate(-50%, -50%);
+    animation: ondaExpandir 1.4s ease-out forwards;
+}
+
+@keyframes ondaExpandir {
+    from { width: 10px; height: 10px; opacity: 0.9; }
+    to { width: 250px; height: 250px; opacity: 0; }
+}
+
+.confeti-fallback {
+    position: fixed;
+    top: -10px;
+    width: 8px;
+    height: 14px;
+    border-radius: 2px;
+    z-index: 10001;
+    animation: caerConfetiFallback 1.8s linear forwards;
+}
+
+@keyframes caerConfetiFallback {
+    to {
+        transform: translateY(110vh) rotate(720deg);
+        opacity: 0;
+    }
+}